---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const entries = (await getCollection('log'))
  .sort((a, b) => b.data.dispatch - a.data.dispatch);

const typeColors: Record<string, string> = {
  essay:          'text-[var(--color-copper)]',
  fragment:       'text-[var(--color-text-muted)]',
  postmortem:     'text-[var(--color-status-blocked)]',
  decision:       'text-[var(--color-copper-dim)]',
  'render-log':   'text-[var(--color-status-active)]',
  'status-update':'text-[var(--color-amber)]',
};
---

<Base title="log" description="All dispatches from the factory-floor build journal.">
  <h1 class="font-mono text-xs uppercase tracking-widest text-[var(--color-text-faint)] mb-10">dispatches</h1>
  <ul class="space-y-8 list-none p-0 m-0">
    {entries.map((entry) => {
      const typeColor = typeColors[entry.data.type] ?? 'text-[var(--color-text-muted)]';
      return (
        <li class="border-b border-[var(--color-border)] pb-8">
          <div class="flex items-center gap-3 mb-2 text-xs font-mono text-[var(--color-text-muted)]">
            <time datetime={entry.data.date.toISOString()}>
              {entry.data.date.toLocaleDateString('en-AU', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
            <span>·</span>
            <span class="text-[var(--color-text-faint)]">#{entry.data.dispatch}</span>
            <span>·</span>
            <span class:list={[typeColor]}>{entry.data.type}</span>
            {entry.data.project && (
              <>
                <span>·</span>
                <span class="text-[var(--color-text-faint)]">{entry.data.project}</span>
              </>
            )}
          </div>
          <a
            href={`/log/${entry.id}/`}
            class="font-serif text-xl text-[var(--color-text)] no-underline hover:text-[var(--color-copper)] transition-colors block mb-2"
          >
            {entry.data.title}
          </a>
          {entry.data.description && (
            <p class="text-sm text-[var(--color-text-muted)] m-0 leading-relaxed">{entry.data.description}</p>
          )}
        </li>
      );
    })}
  </ul>
</Base>
