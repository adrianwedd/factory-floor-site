---
import StatusBadge from './StatusBadge.astro';

interface Props {
  name: string;
  status: string;
  material?: string;
  printer_profile?: string;
  note?: string;
}
const { name, status, material, printer_profile, note } = Astro.props;
---

<div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-5 flex flex-col gap-3">
  <div class="flex items-start justify-between gap-3">
    <h3 class="font-mono text-sm font-medium text-[var(--color-text)] m-0">{name}</h3>
    <StatusBadge status={status} />
  </div>
  {(material || printer_profile) && (
    <div class="flex gap-3 text-xs font-mono text-[var(--color-text-muted)]">
      {material && <span>{material.replace(/_/g, ' ')}</span>}
      {material && printer_profile && <span>·</span>}
      {printer_profile && <span>{printer_profile.replace(/_/g, '-')}</span>}
    </div>
  )}
  {note && <p class="text-xs text-[var(--color-text-muted)] m-0 leading-relaxed">{note}</p>}
</div>
