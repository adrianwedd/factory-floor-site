---
interface Props {
  dispatch: number;
  date: Date;
  type: string;
  project?: string;
}
const { dispatch, date, type, project } = Astro.props;

const typeColors: Record<string, string> = {
  essay:          'text-[var(--color-copper)]',
  fragment:       'text-[var(--color-text-muted)]',
  postmortem:     'text-[var(--color-status-blocked)]',
  decision:       'text-[var(--color-copper-dim)]',
  'render-log':   'text-[var(--color-status-active)]',
  'status-update':'text-[var(--color-amber)]',
};
const typeColor = typeColors[type] ?? 'text-[var(--color-text-muted)]';

const formatted = date.toLocaleDateString('en-AU', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<div class="relative mb-8">
  <span
    aria-hidden="true"
    class="absolute -top-2 -left-4 select-none font-mono text-7xl font-bold leading-none text-[var(--color-border)] pointer-events-none"
  >
    #{dispatch}
  </span>
  <div class="relative flex flex-wrap items-center gap-3 text-sm font-sans text-[var(--color-text-muted)]">
    <time datetime={date.toISOString()}>{formatted}</time>
    <span aria-hidden="true">·</span>
    <span class:list={['font-medium', typeColor]}>{type}</span>
    {project && (
      <>
        <span aria-hidden="true">·</span>
        <span class="text-[var(--color-text-faint)]">{project}</span>
      </>
    )}
  </div>
</div>
