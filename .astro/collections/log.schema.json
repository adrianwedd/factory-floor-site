{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "dispatch": {
      "type": "number"
    },
    "type": {
      "type": "string",
      "enum": [
        "essay",
        "fragment",
        "postmortem",
        "decision",
        "render-log",
        "status-update"
      ]
    },
    "project": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date",
    "dispatch",
    "type"
  ]
}